sysbus.spi1.mySensor Transmit 0x1F
sysbus.spi1.mySensor FinishTransmission
sysbus.spi1.mySensor Transmit 0xE1
sysbus.spi1.mySensor Transmit 0x00
sysbus.spi1.mySensor FinishTransmission

# 9b. Test Reserved Bits
