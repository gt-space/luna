# 1. Load your custom C# model into Renode's memory
include @C:\Users\natha\coding\test.cs

# 2. Create the virtual environment
mach create "Magnotometer"

# 3. Load the motherboard (provides the sysbus and spi1)
machine LoadPlatformDescription @platforms/boards/stm32f4_discovery.repl

# 4. Attach your custom sensor to the SPI bus
machine LoadPlatformDescriptionFromString "mySensor: Antmicro.Renode.Peripherals.Sensors.LIS2MDLTR @ spi1"

# The following tests should be done independently by number
# Meaning only one test should be on this .resc file at a time while the others are stored elsewhere
# ie. to test INT_SOURCE_REG, only have test "5." pasted here

# 5. Test INT_SOURCE_REG
sysbus.spi1.mySensor Transmit 0xE4
sysbus.spi1.mySensor Transmit 0x00
sysbus.spi1.mySensor FinishTransmission

# 5b. Test STATUS_REG
sysbus.spi1.mySensor Transmit 0xE7
sysbus.spi1.mySensor Transmit 0x00
sysbus.spi1.mySensor FinishTransmission

# 6. Read all registers
sysbus.spi1.mySensor Transmit 0xC5
sysbus.spi1.mySensor Transmit 0x00
