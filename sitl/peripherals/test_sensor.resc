# 8. Test CFG_REG_A
sysbus.spi1.mySensor Transmit 0x60
sysbus.spi1.mySensor Transmit 0x9F
sysbus.spi1.mySensor FinishTransmission
sysbus.spi1.mySensor Transmit 0xE0
sysbus.spi1.mySensor Transmit 0x00
sysbus.spi1.mySensor FinishTransmission

# 8b. Test Reset Flags
sysbus.spi1.mySensor Transmit 0x60
sysbus.spi1.mySensor Transmit 0x20
sysbus.spi1.mySensor FinishTransmission
sysbus.spi1.mySensor Transmit 0xE0
sysbus.spi1.mySensor Transmit 0x00
sysbus.spi1.mySensor FinishTransmission

sysbus.spi1.mySensor Transmit 0x60
sysbus.spi1.mySensor Transmit 0x40
